# Symta runtime build — Linux x86-64.
#
# Mirrors Makefile.osx; the differences are:
#   - linux/ subdir instead of osx/ (different mcontext layout)
#   - -ldl   so dlopen/dlsym are available for the FFI loader
#   - -lm    standard math lib (osx folds it into libSystem)
#   - -rdynamic so dlopen-loaded plugins can call back into the
#     runtime's own exported symbols (e.g. heap-aware allocators)
#   - -no-pie because Symta historically pins the executable's image
#     base; not strictly required but it matches the osx -no_pie
#     intent until someone audits PIE-safety.

TARGET = symta
INCLUDE = -I ./runtime -I ./runtime/linux
PREFIX =
CC = $(PREFIX)gcc
rt="./runtime/linux/"
CFLAGS = -O2 -Wno-return-type -Wno-pointer-sign \
         -fno-stack-protector -fno-strict-aliasing \
         $(INCLUDE)
#CFLAGS = -g -O0 -Wno-return-type -Wno-pointer-sign -fno-strict-aliasing $(INCLUDE)
EXTRA_CFLAGS =

AS = $(CC)
ASFLAGS = $(LOC) -Wall

LD = $(CC) -no-pie -rdynamic
LDFLAGS = $(LOC) -ldl -lm
AR = $(PREFIX)ar
ARFLAGS = rcs

STRIP = $(PREFIX)strip
CP = cp -fp
RM = rm -f

SRCS = main.c gc.c ncm.c bltin.c tokenize.c reader.c meta_table.c ng.c \
       sif.c fs.c sbc.c sif2sbc.c \
       sffi/sffi.c sffi/arch_x64_sysv.c \
       linux/ctx.c linux/compat.c

HDRSB = symta.h common.h ng.h prf.h dh.h ih.h th.h am.h nb.h nh.h fs.h sif.h flt16.h flt16_x86.h meta_table.h sffi/sffi.h

HDRS = $(addprefix runtime/,$(HDRSB))

OBJS = $(addprefix build/rt/,$(SRCS:.c=.o))
OBJA =

all: $(TARGET)

test:
	@echo "hello"

lib/:
	mkdir lib

src/%.h:
	@echo "header \"$@\" is missing"
	@exit -1

build/rt/ncm.o: runtime/ncm.h

build/rt/gc.o: runtime/gc_types.h

build/rt/linux:
	@mkdir -p build/rt/linux
	@mkdir -p build/rt/sffi

build/rt/%.o: runtime/%.c $(HDRS)
	@echo CC $<
	@$(CC) $(CFLAGS) $(EXTRA_CFLAGS) -c -o $@ $<

$(TARGET): build/rt/linux $(OBJS) $(OBJA)
	@echo LINK $@
	@$(LD) -o $@ $(OBJS) $(OBJA) $(LDFLAGS)

lib/util: lib/ $(OBJS) lib/util.o $(OBJA)
	$(LD) -o $@ $(OBJS) lib/util.o $(OBJA) $(LDFLAGS)

.PHONY: install uninstall clean

clean:
	-$(RM) $(TARGET)
	-$(RM) *.o
