TARGET = symta
INCLUDE = -I ./runtime -I ./runtime/w64
PREFIX =
CC = $(PREFIX)gcc
rt="./runtime/w64/"
# -fno-stack-protector -fomit-frame-pointer -fno-exceptions -fno-unwind-tables -fno-ident


CFLAGS = -O2 -march=corei7 -Wno-return-type -Wno-pointer-sign -fvisibility=hidden -fno-stack-protector -fomit-frame-pointer -fno-exceptions -fno-unwind-tables -fno-ident \
  -fgcse-after-reload \
  -fipa-cp-clone \
  -floop-interchange \
  -floop-unroll-and-jam \
  -fpeel-loops \
  -fpredictive-commoning \
  -fsplit-loops \
  -fsplit-paths \
  -ftree-loop-distribution \
  -ftree-partial-pre \
  -funswitch-loops \
  -fvect-cost-model=dynamic \
  -fversion-loops-for-strides \
  -D WINDOWS $(INCLUDE)

#CFLAGS = -O2 -Wno-return-type -Wno-pointer-sign -D WINDOWS $(INCLUDE)
#CFLAGS = -g -O0 -Wno-return-type -Wno-pointer-sign -D WINDOWS $(INCLUDE)
#CFLAGS = -g -O2 -Wno-return-type -Wno-pointer-sign -D WINDOWS $(INCLUDE)

EXTRA_CFLAGS = 

AS = $(CC)
ASFLAGS = $(LOC) -Wall

LD = $(CC) -Wl,--stack,67108864
# -Wl,-allow_stack_execute
LDFLAGS = $(LOC) -Wl,--exclude-all-symbols -Wl,--exclude-libs,ALL
AR = $(PREFIX)ar
ARFLAGS = rcs

STRIP = $(PREFIX)strip
CP = cp -fp
RM = rm -f

SRCS = main.c gc.c ncm.c bltin.c tokenize.c reader.c ng.c \
       sif.c fs.c sbc.c sif2sbc.c \
       sffi/sffi.c sffi/arch_x64_win.c \
       w64/ctx.c w64/compat.c w64/dlfcn.c w64/mman.c

HDRSB = symta.h common.h ng.h prf.h dh.h am.h nb.h nh.h fs.h sif.h flt16.h flt16_x86.h reader.h sffi/sffi.h

HDRS = $(addprefix runtime/,$(HDRSB))

OBJS = $(addprefix build/rt/,$(SRCS:.c=.o))
OBJA =

#$(info $$OBJS is [${OBJS}])


all: $(TARGET)

test:
	@echo "Hello World!"

lib/:
	mkdir lib

src/%.h:
	@echo "header \"$@\" is missing"
	@exit -1

# -save-temps=obj

build/rt/ncm.o: runtime/ncm.h

build/rt/gc.o: runtime/gc_types.h

build/rt/w64:
	@mkdir -p build/rt/w64
	@mkdir -p build/rt/sffi

build/rt/%.o: runtime/%.c $(HDRS)
	@echo CC $<
	@$(CC) $(CFLAGS) $(EXTRA_CFLAGS) -c -o $@ $<

build\rt\%.o: runtime\%.c $(HDRS)
	@echo CC $<
	@$(CC) $(CFLAGS) $(EXTRA_CFLAGS) -c -o $@ $<

$(TARGET): build/rt/w64 $(OBJS) $(OBJA)
	@echo LINK $@
	@$(LD) -o $@ $(OBJS) $(OBJA) $(LDFLAGS)

lib/util: lib/ $(OBJS) lib/util.o $(OBJA)
	$(LD) -o $@ $(OBJS) lib/util.o $(OBJA) $(LDFLAGS)

.PHONY: install uninstall clean

clean:
	-$(RM) $(TARGET)
	-$(RM) *.o
	-$(RM) *.exe


