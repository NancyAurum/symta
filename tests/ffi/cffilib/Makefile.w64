# Build the cffilib shared library on Windows x86-64 (w64devkit).
# Output: lib/cffi.ffi — a renamed DLL that Symta's ffi_load picks up.

TARGET    = lib/cffi.ffi
CC       ?= gcc
CFLAGS   ?= -O2 -Wall -Wextra -Wno-unused-parameter \
            -fvisibility=hidden -fno-stack-protector
LDFLAGS  ?= -shared -Wl,--exclude-all-symbols

SRCS = src/cffilib.c
OBJS = $(SRCS:src/%.c=lib/%.o)

all: $(TARGET)

lib:
	mkdir -p lib

lib/%.o: src/%.c | lib
	$(CC) $(CFLAGS) -c -o $@ $<

$(TARGET): $(OBJS)
	$(CC) $(LDFLAGS) -o $@ $(OBJS)

.PHONY: clean
clean:
	-rm -f $(OBJS) $(TARGET)
