hex:
  ((255))
binary:
  ((10))
float (synthesised from int . int):
  ((3.1400001))
  ((0.5))
symbol (lowercase):
  ((foo))
symbol (uppercase first):
  ((Foo))
quoted single word:
  (((`\\` Foo)))
single-quoted text:
  (((`\\` hello)))
