inline if/then/else:
  (((`if` (X) (A) (B))))
inline if with `:`:
  (((`if` (X) (A) (B))))
  (((`if` (X) (A) ())))
if: cond-chain form (each clause is `Cnd = Body`):
  ((`;` ((`if` `=`)) (`=` (B) (2)) (`=` (1) (0))))
when:
  ((`:` (when X) (A)))
less (= unless):
  ((`:` (less X) (A)))
elif form rewriting:
  (((`if` (X) (A) ((`if` (Y) (B) (C))))))
