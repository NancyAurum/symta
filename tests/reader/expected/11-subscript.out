single index:
  (((`[` Xs 0)))
  (((`[` Xs (`+` A B))))
slice:
  (((`[` Xs (`:` (N) (M)))))
  (((`[` Xs (`:` () (M)))))
  (((`[` Xs (`:` (N) ()))))
slice with step:
  (((`[` Xs (`:` (0) (`:` () (2))))))
  (((`[` Xs (`:` (20) (`:` (-10) (2))))))
last-element shortcut:
  (((`[` Xs `~`)))
  (((`[` Xs (`:` (`~`) (0)))))
negative index:
  (((`[` Xs (`-` I))))
multi-index:
  (((`[` Xs A B C)))
  (((`[` Xs A B C D N)))
replacement at index (N!V):
  (((`[` Xs (`!` N) V)))
  (((`[` Xs (`!` N) V (`!` M) U)))
splice replacement (N!@Ys):
  (((`[` Xs (`!` N) (`@` Ys))))
additive insert (@N!V):
  (((`[` Xs (`!` (`@` N)) V)))
locate (3!):
  (((`[` Xs (`!` 3))))
error-suppressing form (!...):
  (((`[` Xs (`:` (`!` N) (M)))))
  (((`[` Xs `!` 3)))
