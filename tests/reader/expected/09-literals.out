empty list:
  (((`[]`)))
list literal:
  (((`[]` 1 2 3)))
list with mixed:
  (((`[]` 1 X (`"` x))))
splatted list (@-prefix in list ctx):
  (((`[]` 1 (`@` Xs) 2)))
colon-line list:
  ((`:` (Xs) (1 2 3)))
table literal @{}:
  ((@{a!1 b!2}))
object literal ${}:
  (((`${}` (name alice) (age 30))))
nested list:
  (((`[]` (`[]` 1 2) (`[]` 3 4))))
tuple-via-paren:
  (((1 2 3)))
