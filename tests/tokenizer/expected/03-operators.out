arithmetic:
  + +
  - -
  * *
  / /
  unary %
comparison (Symta uses >< for == and <> for !=):
  < <
  > >
  << <<
  >> >>
  >< ><
  unary <>
logical:
  && &&
  || ||
  ! !
  and and
  or or
bitwise (suffix-separated dashes):
  -+- -+-
  -^- -^-
  -*- -*-
  -<- -<-
  ->- ->-
increment / decrement:
  ++ ++
  unary --
method-call / index:
  . .
  ^ ^
  -> ->
  @ @
assignment family:
  = =
  <= <=
  => =>
  += +=
  -= -=
  *= *=
  /= /=
  %= %=
single-quote / backtick / backslash:
`t`:1,6: EOF in string
