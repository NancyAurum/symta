parens:
  type=() val=(#1 #2 #3)
brackets:
  type=[] val=(#a #b #c)
curly:
  type={} val=(#x #y #z)
table form @{}:
  type=@{} val=(#a #! #1 #b #! #2)
object form ${}:
  type=${} val=(#name #! #alice)
nested:
  type=() val=(#a #(#b #(#c) #d))
mixed with op outside:
  type=symbol val=f
  type=() val=(#x)
  type=+ val=+
  type=symbol val=g
  type=[] val=(#y)
