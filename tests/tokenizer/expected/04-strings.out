single-quoted (no interpolation):
  text (`\\` hello)
double-quoted (splice-capable, no incut):
  splice (#hello)
backtick symbol literal:
  symbol +
  symbol name
string with escape sequences:
  text (`\\` `
 	 \\`)
splice with one incut:
  splice (#a #(#X) #b)
splice with two incuts:
  splice (#start #(#X) #mid #(#Y) #end)
empty strings:
  text (`\\` ``)
  splice ()
