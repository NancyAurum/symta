--- plain constants ---

  
 

The window is 640 x 480 pixels.
That is 640*480 total.


--- compile-time #[expr] ---

 
 

    364      = compile-time arithmetic
  12        = bitwise AND/OR/XOR
  7        = precedence (* binds tighter than +)
10     = log2 builtin
  0          = comparison (1 if true, 0 if false)


--- fn-style macros ---

 

 

a := ((7)*(7))
b := ((3)*(3)) + ((4)*(4))
c := ((2+1)*(2+1)) + (( 4)*( 4))            // inner expressions OK if you parenthesize


--- optional args ---

 
 

a := hello, World!
b := hello, Symta!
c := [info] "started"
d := [ error] "boom"


--- variadic ---

 
 

a := [1, 2, 3, 4]
b := printf  "value=%d\n", v


--- body args ---

 

 if (!(ready)) { 
#line 4 "<demo>"
 wait(); retry();  }


--- conditionals ---

 
 

 
#line 6 "<demo>"
slow_path_with_assertions();
#line 7 "<demo>"
#line 9 "<demo>"
#line 11 "<demo>"

 
 
#line 16 "<demo>"

debug now disabled
#line 18 "<demo>"


--- format with #(...) ---

 
 
 

color = 0xffa040;
id    = ent_00042;
left  = foo       ;


--- escaping ---

 
1) 42 is here -> 42
2) # stays literal
3) "X is also literal inside quotes"


